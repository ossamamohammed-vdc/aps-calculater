<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>APS vs Self-Hosted Automation — Cost Model</title>
<style>
  :root{
    --ink:#14181F; --paper:#F6F7F9; --aps:#2563EB; --host:#D97706;
    --rule:#D6DAE0; --muted:#5A636E; --faint:#8A929C;
    --mono:ui-monospace,"SF Mono",Menlo,Consolas,monospace;
    --sans:"Inter",system-ui,-apple-system,Segoe UI,Roboto,sans-serif;
  }
  *{box-sizing:border-box;}
  body{margin:0;background:#E9EBEF;font-family:var(--sans);color:var(--ink);
    display:flex;justify-content:center;padding:24px;}
  .card{background:var(--paper);max-width:1040px;width:100%;border-radius:4px;
    padding:28px 26px;box-shadow:0 1px 3px rgba(0,0,0,.08);}

  header{border-bottom:2px solid var(--ink);padding-bottom:14px;margin-bottom:24px;}
  .eyebrow{font-family:var(--mono);font-size:11px;color:var(--faint);letter-spacing:.08em;}
  h1{font-size:25px;font-weight:800;margin:4px 0 0;letter-spacing:-.01em;}
  .sub{font-size:13px;color:var(--muted);margin-top:4px;}

  .grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1.15fr);gap:32px;}
  @media(max-width:760px){.grid{grid-template-columns:1fr;}}

  .sec{margin-bottom:24px;}
  .sec-head{display:flex;align-items:center;gap:8px;margin-bottom:14px;}
  .tag{font-family:var(--mono);font-size:11px;font-weight:700;border:1px solid currentColor;
    border-radius:2px;padding:1px 5px;}
  .sec-title{font-size:13px;font-weight:700;letter-spacing:.02em;color:var(--ink);}

  .field{display:block;margin-bottom:14px;}
  .field .lab{font-size:11px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);
    display:block;margin-bottom:4px;}
  .field .row{display:flex;align-items:baseline;border-bottom:1.5px solid var(--rule);}
  .field input{width:100%;border:none;outline:none;background:transparent;font-family:var(--mono);
    font-size:20px;font-weight:600;color:var(--ink);padding:3px 0;}
  .field .row:focus-within{border-bottom-color:var(--ink);}
  .field .unit{font-size:12px;color:var(--faint);margin-left:6px;white-space:nowrap;}
  .note{font-size:11px;color:var(--faint);margin-top:-4px;}

  .cards2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px;}
  .stat{border-radius:3px;padding:14px 16px;background:#fff;}
  .stat.aps{border:1.5px solid var(--aps);}
  .stat.host{border:1.5px solid var(--host);}
  .stat .k{font-size:11px;font-weight:700;letter-spacing:.04em;}
  .stat.aps .k{color:var(--aps);} .stat.host .k{color:var(--host);}
  .stat .v{font-family:var(--mono);font-size:30px;font-weight:700;margin-top:2px;}
  .stat .s{font-size:11px;color:var(--faint);margin-top:2px;}

  .be{background:var(--ink);color:#fff;border-radius:3px;padding:12px 16px;margin-bottom:18px;
    display:flex;justify-content:space-between;align-items:center;}
  .be .k{font-size:11px;color:#9AA3AE;letter-spacing:.04em;}
  .be .v{font-family:var(--mono);font-size:22px;font-weight:700;}
  .be .verdict{font-size:15px;font-weight:700;}

  .chartbox{background:#fff;border:1px solid var(--rule);border-radius:3px;padding:14px 10px 8px;}
  .legend{display:flex;gap:18px;justify-content:center;font-size:11px;color:var(--muted);padding-top:4px;}
  .legend b.aps{color:var(--aps);} .legend b.host{color:var(--host);}

  .factors{margin-top:16px;font-size:12px;color:var(--muted);line-height:1.55;
    border-left:3px solid var(--rule);padding-left:12px;}
  .factors strong{color:var(--ink);}

  svg text{font-family:var(--mono);}
</style>
</head>
<body>
<div class="card">
  <header>
    <div class="eyebrow">VDC · AUTOMATION INFRASTRUCTURE · COST MODEL</div>
    <h1>APS Flex Tokens vs. Self-Hosted Automation</h1>
    <div class="sub">Consumption vs. ownership — find the volume where running our own environment wins.</div>
  </header>

  <div class="grid">
    <!-- INPUTS -->
    <div>
      <div class="sec">
        <div class="sec-head" style="color:var(--ink)"><span class="tag">01</span><span class="sec-title">Workload</span></div>
        <label class="field"><span class="lab">Models per month</span>
          <span class="row"><input id="models" type="number" value="500" min="0" step="50"></span></label>
        <label class="field"><span class="lab">Avg processing time</span>
          <span class="row"><input id="mins" type="number" value="40" min="0" step="5"><span class="unit">min / model</span></span></label>
      </div>

      <div class="sec">
        <div class="sec-head" style="color:var(--aps)"><span class="tag">A</span><span class="sec-title">APS Automation API</span></div>
        <label class="field"><span class="lab">Tokens per processing hour</span>
          <span class="row"><input id="tph" type="number" value="2" min="0" step="0.5"><span class="unit">tokens</span></span></label>
        <label class="field"><span class="lab">Flex token price</span>
          <span class="row"><input id="tprice" type="number" value="3" min="0" step="0.25"><span class="unit">USD / token</span></span></label>
        <div class="note">Autodesk list: 2 tokens/hr · $3/token → ≈ $6 per processing hour.</div>
      </div>

      <div class="sec">
        <div class="sec-head" style="color:var(--host)"><span class="tag">B</span><span class="sec-title">Self-Hosted Windows</span></div>
        <label class="field"><span class="lab">Cloud VM</span>
          <span class="row"><input id="vm" type="number" value="450" min="0" step="50"><span class="unit">USD / month</span></span></label>
        <label class="field"><span class="lab">Concurrent Revit/Navis seats</span>
          <span class="row"><input id="seats" type="number" value="4" min="0" step="1"><span class="unit">licenses</span></span></label>
        <label class="field"><span class="lab">Autodesk license per seat</span>
          <span class="row"><input id="lic" type="number" value="3300" min="0" step="100"><span class="unit">USD / year</span></span></label>
        <label class="field"><span class="lab">Admin, patching, add-in mgmt</span>
          <span class="row"><input id="maint" type="number" value="350" min="0" step="50"><span class="unit">USD / month</span></span></label>
      </div>
    </div>

    <!-- OUTPUTS -->
    <div>
      <div class="cards2">
        <div class="stat aps"><div class="k">APS / MONTH</div><div class="v" id="apsMon">—</div><div class="s" id="apsPer">—</div></div>
        <div class="stat host"><div class="k">SELF-HOST / MONTH</div><div class="v" id="hostMon">—</div><div class="s">fixed, regardless of volume</div></div>
      </div>

      <div class="be">
        <div><div class="k">BREAK-EVEN</div><div class="v" id="beVal">—</div></div>
        <div style="text-align:right"><div class="k">AT CURRENT VOLUME</div><div class="verdict" id="verdict">—</div></div>
      </div>

      <div class="chartbox">
        <svg id="chart" viewBox="0 0 460 240" width="100%" height="240" preserveAspectRatio="xMidYMid meet"></svg>
        <div class="legend">
          <span><b class="aps">—</b> APS (scales with volume)</span>
          <span><b class="host">– –</b> Self-host (fixed)</span>
        </div>
      </div>

      <div class="factors">
        <strong>Cost isn't the only axis.</strong> APS runs headless AppBundles only — it can't run your existing
        WPF/ExternalEvent add-ins unmodified. Self-host runs your current code as-is, but you own licensing,
        patching, and the licensing-compliance question on automated sessions. Use cost for the break-even;
        use capability for the recommendation.
      </div>
    </div>
  </div>
</div>

<script>
  const $ = id => document.getElementById(id);
  const ids = ["models","mins","tph","tprice","vm","seats","lic","maint"];
  ids.forEach(id => $(id).addEventListener("input", render));

  function money(n){
    if(!isFinite(n)) return "—";
    return n >= 1000 ? "$"+Math.round(n).toLocaleString()
      : "$"+ (n<10 ? n.toFixed(2) : Math.round(n).toLocaleString());
  }

  function render(){
    const models = +$("models").value || 0;
    const mins   = +$("mins").value   || 0;
    const tph    = +$("tph").value    || 0;
    const tprice = +$("tprice").value || 0;
    const vm     = +$("vm").value     || 0;
    const seats  = +$("seats").value  || 0;
    const lic    = +$("lic").value    || 0;
    const maint  = +$("maint").value  || 0;

    const apsPer   = (mins/60) * tph * tprice;          // $ per model
    const apsMon   = models * apsPer;
    const hostMon  = vm + seats*(lic/12) + maint;
    const be       = apsPer > 0 ? hostMon/apsPer : Infinity;
    const cheaper  = apsMon <= hostMon ? "APS" : "Self-host";

    $("apsMon").textContent  = money(apsMon);
    $("apsPer").textContent  = money(apsPer) + " per model";
    $("hostMon").textContent = money(hostMon);
    $("beVal").textContent   = isFinite(be) ? Math.round(be).toLocaleString()+" models/mo" : "—";
    const v = $("verdict");
    v.textContent = cheaper + " is cheaper";
    v.style.color = cheaper === "APS" ? "#7FB0FF" : "#FBBF60";

    drawChart(models, apsPer, hostMon, be);
  }

  function drawChart(models, apsPer, hostMon, be){
    const W=460,H=240, pad={l:46,r:14,t:12,b:30};
    const x0=pad.l, x1=W-pad.r, y0=H-pad.b, y1=pad.t;
    const maxX = Math.max(models*2, isFinite(be)?be*1.6:0, 200);
    const maxY = Math.max(maxX*apsPer, hostMon) * 1.12 || 1;

    const sx = v => x0 + (v/maxX)*(x1-x0);
    const sy = v => y0 - (v/maxY)*(y0-y1);

    let s = "";
    for(let i=0;i<=4;i++){
      const yv = maxY*i/4, y = sy(yv);
      s += `<line x1="${x0}" y1="${y}" x2="${x1}" y2="${y}" stroke="#EDEFF2"/>`;
      s += `<text x="${x0-6}" y="${y+3}" text-anchor="end" font-size="9" fill="#8A929C">$${Math.round(yv/1000)}k</text>`;
    }
    for(let i=0;i<=4;i++){
      const xv = maxX*i/4, x = sx(xv);
      s += `<text x="${x}" y="${y0+15}" text-anchor="middle" font-size="9" fill="#8A929C">${Math.round(xv).toLocaleString()}</text>`;
    }
    s += `<text x="${(x0+x1)/2}" y="${H-4}" text-anchor="middle" font-size="9" fill="#8A929C">models / month</text>`;
    s += `<line x1="${x0}" y1="${y0}" x2="${x1}" y2="${y0}" stroke="#D6DAE0"/>`;
    const hy = sy(hostMon);
    s += `<line x1="${x0}" y1="${hy}" x2="${x1}" y2="${hy}" stroke="#D97706" stroke-width="2.5" stroke-dasharray="5 4"/>`;
    s += `<line x1="${sx(0)}" y1="${sy(0)}" x2="${sx(maxX)}" y2="${sy(maxX*apsPer)}" stroke="#2563EB" stroke-width="2.5"/>`;
    if(isFinite(be) && be<=maxX){
      const bx=sx(be);
      s += `<line x1="${bx}" y1="${y1}" x2="${bx}" y2="${y0}" stroke="#14181F" stroke-dasharray="2 3"/>`;
      s += `<circle cx="${bx}" cy="${hy}" r="4" fill="#14181F" stroke="#fff" stroke-width="1.5"/>`;
    }
    $("chart").innerHTML = s;
  }

  render();
</script>
</body>
</html>
